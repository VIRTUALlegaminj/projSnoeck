// Online C++ compiler to run C++ program online
#include <iostream>
#include <string>
#include <vector>
#include <cmath>
#include <iomanip>
#include <sstream>

class Bank{
    public: 
    std::string name;
    std::vector<int> durations;
    std::vector<float> rates;
    std::vector<float> results;
    //int duration1, duration2, duration3;
    float capital;
    //float rate1, rate2;
    
    Bank(std::string selectName, int selectDuration1, int selectDuration2, int selectDuration3, float selectRate1, float selectRate2) {
        name = selectName;
        durations.push_back(selectDuration1);
        durations.push_back(selectDuration2);
        durations.push_back(selectDuration3);
        rates.push_back(selectRate1);
        rates.push_back(selectRate2);
    }
    
    void readCapital() {
        std::cout << "Enter capital pour " <<name << " : ";
        std::cin >> capital;
    }
    
    void calculateValues() {
    results.clear(); 

        for (int i = 0; i < durations.size(); i++) {
            for (int j = 0; j < rates.size(); j++) {
    
                float r = rates[j] * 0.01f; // conversion en taux %
                float value = capital * std::pow(1.0f + r, durations[i]);
                results.push_back(value);
            }
        }
    }
    
    void printValues() {
        std::cout << "\n========================\n";
        std::cout << "          " << name << "\n";
        std::cout << "========================\n\n";
    
        int index = 0;
    
        for (int j = 0; j < rates.size(); j++) {
            for (int i = 0; i < durations.size(); i++) {
    
                std::cout << "Taux:" << (j+1) << "     " << rates[j] << "%\n";
                std::cout << "Duree:" << (i+1) << "    " << durations[i] << " ans\n";
                std::cout << "Montant:   " << results[index] << " €\n";
                std::cout << "------------------------\n";
                index++;
            }
        }
    }
};

class BankManager{
    public: 
    std::vector<Bank> bankList;
    
    void addBank(Bank &selectBankToAdd) {
        bankList.push_back(selectBankToAdd);
    }
    
    void printValues() {
    int spacing = 15;
    
    // Ligne d'en-tête : noms des banques
    std::cout << std::left << std::setw(spacing) << ""; // colonne 1 vide
    for (const auto& b : bankList)
        std::cout << std::left << std::setw(spacing) << b.name;
    std::cout << "\n";
    
    int nbDur   = bankList[0].durations.size();
    int nbRates = bankList[0].rates.size();
    
    for (int j = 0; j < nbRates; j++) {
        for (int i = 0; i < nbDur; i++) {
            int index = j * nbDur + i;
            
            // Ligne Taux
            std::cout << std::left << std::setw(spacing) << ("Taux" + std::to_string(j+1));
            for (const auto& b : bankList)
                std::cout << std::left << std::setw(spacing) << b.rates[j];
            std::cout << "\n";
            
            // Ligne Duree
            std::cout << std::left << std::setw(spacing) << ("Duree" + std::to_string(i+1));
            for (const auto& b : bankList)
                std::cout << std::left << std::setw(spacing) << b.durations[i];
            std::cout << "\n";
            
            // Ligne Resultat
            std::cout << std::left << std::setw(spacing) << "Resultat";
            for (const auto& b : bankList) {
                std::stringstream ss;
                ss << std::fixed << std::setprecision(2) << b.results[index];
                std::cout << std::left << std::setw(spacing) << ss.str();
            }
            std::cout << "\n";
        }
    }
}



};



int main() {
    BankManager myBankManager;
    
    Bank bank1("LCL",10,15,20,3,4);
    Bank bank2("BNP",10,15,20,3,4);
    Bank bank3("CA",10,15,20,3,4);
    
    myBankManager.addBank(bank1);
    myBankManager.addBank(bank2);
    //myBankManager.addBank(bank3);
    
    for(int i=0; i<myBankManager.bankList.size(); i++) {
        myBankManager.bankList[i].readCapital();
    }
    
    for(int i=0; i<myBankManager.bankList.size(); i++) {
        myBankManager.bankList[i].calculateValues();
    }
    
    myBankManager.printValues();
    
    
    
    
    return 0;
}
